<script>
  let selectedCourse = '';

  function selectCourse(el, name) {
    // Deselect all
    document.querySelectorAll('.course-card').forEach(c => c.classList.remove('selected'));
    // Select clicked
    el.classList.add('selected');
    selectedCourse = name;
    // Update display
    document.getElementById('selectedCourseDisplay').textContent = '✅ ' + name;
    document.getElementById('noCourseWarning').style.display = 'none';
    // Scroll to form smoothly after short delay
    setTimeout(() => {
      document.querySelector('.form-section').scrollIntoView({ behavior: 'smooth', block: 'start' });
    }, 400);
  }

  function sendToWhatsApp() {
    const name = document.getElementById('fullName').value.trim();
    const phone = document.getElementById('phone').value.trim();
    const location = document.getElementById('location').value.trim();
    const payMethod = document.getElementById('payMethod').value;
    const payRef = document.getElementById('payRef').value.trim();

    if (!selectedCourse) {
      document.getElementById('noCourseWarning').style.display = 'block';
      document.querySelector('.courses-wrap').scrollIntoView({ behavior: 'smooth' });
      return;
    }
    if (!name) { alert('Please enter your full name.'); return; }
    if (!phone) { alert('Please enter your phone number.'); return; }
    if (!location) { alert('Please enter your location.'); return; }
    if (!payMethod) { alert('Please select your payment method.'); return; }

    const msg =
`🌍 *G WORLD — COURSE REGISTRATION*

📚 *Course Selected:* ${selectedCourse}

👤 *Full Name:* ${name}
📞 *Phone (WhatsApp):* ${phone}
📍 *Location:* ${location}

💳 *Payment Method:* ${payMethod}
💰 *Amount Paid:* D1,000
🧾 *Payment Reference:* ${payRef || 'See screenshot attached'}

✅ I have made my payment and I am ready to start!`;

    const encoded = encodeURIComponent(msg);
    const waNumber = '2205169263';
    const url = `https://wa.me/${waNumber}?text=${encoded}`;
    window.open(url, '_blank');
  }
</script>
