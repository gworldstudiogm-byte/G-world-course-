<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>G WORLD – Make Money Online</title>
<link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Outfit:wght@300;400;500;600;700&display=swap" rel="stylesheet">
<style>
  :root {
    --gold: #F5C518;
    --gold2: #FFD700;
    --dark: #0a0a0a;
    --dark2: #111111;
    --dark3: #1a1a1a;
    --card: #161616;
    --text: #f0f0f0;
    --muted: #888;
    --green: #25D366;
    --wave: #009CDE;
    --afri: #E31837;
    --eco: #2E7D32;
    --qmoney: #FF6600;
  }

  * { margin: 0; padding: 0; box-sizing: border-box; }

  body {
    background: var(--dark);
    color: var(--text);
    font-family: 'Outfit', sans-serif;
    overflow-x: hidden;
  }

  /* HERO */
  .hero {
    min-height: 100vh;
    background: var(--dark);
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    text-align: center;
    padding: 40px 20px;
    position: relative;
    overflow: hidden;
  }

  .hero::before {
    content: '';
    position: absolute;
    width: 700px; height: 700px;
    border-radius: 50%;
    background: radial-gradient(circle, rgba(245,197,24,0.12) 0%, transparent 70%);
    top: 50%; left: 50%;
    transform: translate(-50%, -50%);
    pointer-events: none;
  }

  .hero-badge {
    background: rgba(245,197,24,0.1);
    border: 1px solid rgba(245,197,24,0.3);
    color: var(--gold);
    padding: 6px 18px;
    border-radius: 50px;
    font-size: 0.78rem;
    letter-spacing: 2px;
    text-transform: uppercase;
    margin-bottom: 24px;
    font-weight: 600;
    animation: fadeUp 0.6s ease both;
  }

  .hero h1 {
    font-family: 'Bebas Neue', sans-serif;
    font-size: clamp(5rem, 18vw, 12rem);
    line-height: 0.9;
    color: var(--gold);
    letter-spacing: 4px;
    animation: fadeUp 0.7s ease 0.1s both;
    text-shadow: 0 0 80px rgba(245,197,24,0.25);
  }

  .hero-sub {
    font-size: clamp(1rem, 2.5vw, 1.3rem);
    color: var(--muted);
    max-width: 560px;
    line-height: 1.6;
    margin: 20px auto 0;
    animation: fadeUp 0.7s ease 0.2s both;
  }

  .hero-sub span { color: var(--gold); font-weight: 600; }

  .price-banner {
    margin: 36px auto 0;
    background: linear-gradient(135deg, var(--gold), #e6a800);
    color: #000;
    padding: 16px 40px;
    border-radius: 12px;
    font-size: 1.5rem;
    font-weight: 700;
    letter-spacing: 1px;
    animation: fadeUp 0.7s ease 0.3s both;
    box-shadow: 0 8px 40px rgba(245,197,24,0.3);
  }

  .price-banner small {
    display: block;
    font-size: 0.75rem;
    font-weight: 500;
    opacity: 0.7;
    margin-top: 2px;
  }

  .scroll-hint {
    margin-top: 50px;
    color: var(--muted);
    font-size: 0.8rem;
    letter-spacing: 2px;
    text-transform: uppercase;
    animation: bounce 2s infinite;
  }

  /* SECTION STYLES */
  section { padding: 80px 20px; max-width: 1100px; margin: 0 auto; }
  .section-label {
    font-size: 0.72rem;
    letter-spacing: 3px;
    text-transform: uppercase;
    color: var(--gold);
    font-weight: 600;
    margin-bottom: 12px;
  }
  .section-title {
    font-family: 'Bebas Neue', sans-serif;
    font-size: clamp(2.5rem, 6vw, 4rem);
    line-height: 1;
    margin-bottom: 40px;
    color: var(--text);
  }

  /* COURSE CATEGORIES */
  .courses-wrap { width: 100%; }

  .cat-title {
    font-family: 'Bebas Neue', sans-serif;
    font-size: 1.6rem;
    color: var(--gold);
    letter-spacing: 2px;
    border-left: 4px solid var(--gold);
    padding-left: 14px;
    margin: 40px 0 16px;
  }

  .course-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 12px;
  }

  .course-card {
    background: var(--card);
    border: 1px solid rgba(255,255,255,0.06);
    border-radius: 12px;
    padding: 18px 20px;
    cursor: pointer;
    transition: all 0.25s ease;
    display: flex;
    align-items: center;
    gap: 14px;
    position: relative;
    overflow: hidden;
  }

  .course-card:hover {
    border-color: var(--gold);
    background: rgba(245,197,24,0.06);
    transform: translateY(-2px);
    box-shadow: 0 8px 30px rgba(245,197,24,0.12);
  }

  .course-card.selected {
    border-color: var(--gold);
    background: rgba(245,197,24,0.1);
    box-shadow: 0 0 0 2px rgba(245,197,24,0.3);
  }

  .course-card.selected::after {
    content: '✓';
    position: absolute;
    right: 14px;
    top: 50%;
    transform: translateY(-50%);
    background: var(--gold);
    color: #000;
    width: 22px; height: 22px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 0.75rem;
    font-weight: 700;
  }

  .course-num {
    min-width: 30px; height: 30px;
    background: rgba(245,197,24,0.1);
    border: 1px solid rgba(245,197,24,0.2);
    border-radius: 8px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 0.75rem;
    font-weight: 700;
    color: var(--gold);
  }

  .course-name {
    font-size: 0.9rem;
    font-weight: 500;
    line-height: 1.4;
    color: var(--text);
    padding-right: 28px;
  }

  /* PAYMENT SECTION */
  .payment-section {
    background: var(--dark2);
    border-top: 1px solid rgba(255,255,255,0.05);
    border-bottom: 1px solid rgba(255,255,255,0.05);
    padding: 80px 20px;
  }

  .payment-inner { max-width: 1100px; margin: 0 auto; }

  .payment-methods {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
    gap: 16px;
    margin-top: 40px;
  }

  .pay-card {
    background: var(--card);
    border: 1px solid rgba(255,255,255,0.07);
    border-radius: 14px;
    padding: 24px 20px;
    text-align: center;
    transition: all 0.2s;
  }

  .pay-card:hover { transform: translateY(-3px); }

  .pay-icon {
    width: 56px; height: 56px;
    border-radius: 14px;
    display: flex;
    align-items: center;
    justify-content: center;
    margin: 0 auto 14px;
    font-size: 1.6rem;
  }

  .pay-name {
    font-family: 'Bebas Neue', sans-serif;
    font-size: 1.4rem;
    letter-spacing: 1px;
    margin-bottom: 6px;
  }

  .pay-number {
    font-size: 1rem;
    font-weight: 600;
    letter-spacing: 1px;
    margin-bottom: 4px;
  }

  .pay-label {
    font-size: 0.75rem;
    color: var(--muted);
  }

  /* REGISTRATION FORM */
  .form-section { max-width: 680px; margin: 0 auto; padding: 80px 20px; }

  .form-box {
    background: var(--card);
    border: 1px solid rgba(255,255,255,0.07);
    border-radius: 20px;
    padding: 40px;
  }

  .form-group { margin-bottom: 20px; }

  label {
    display: block;
    font-size: 0.78rem;
    letter-spacing: 1.5px;
    text-transform: uppercase;
    color: var(--muted);
    margin-bottom: 8px;
    font-weight: 600;
  }

  input, select, textarea {
    width: 100%;
    background: var(--dark3);
    border: 1px solid rgba(255,255,255,0.08);
    border-radius: 10px;
    padding: 14px 16px;
    color: var(--text);
    font-family: 'Outfit', sans-serif;
    font-size: 0.95rem;
    transition: border 0.2s;
    outline: none;
    -webkit-appearance: none;
  }

  input:focus, select:focus, textarea:focus {
    border-color: var(--gold);
    box-shadow: 0 0 0 3px rgba(245,197,24,0.1);
  }

  select option { background: #1a1a1a; }

  textarea { resize: vertical; min-height: 90px; }

  .selected-course-display {
    background: rgba(245,197,24,0.08);
    border: 1px solid rgba(245,197,24,0.25);
    border-radius: 10px;
    padding: 12px 16px;
    color: var(--gold);
    font-size: 0.9rem;
    font-weight: 500;
    min-height: 48px;
  }

  .amount-display {
    background: var(--dark3);
    border: 1px solid rgba(245,197,24,0.3);
    border-radius: 10px;
    padding: 14px 16px;
    color: var(--gold);
    font-size: 1.1rem;
    font-weight: 700;
    letter-spacing: 1px;
  }

  .submit-btn {
    width: 100%;
    background: linear-gradient(135deg, var(--gold), #e6a800);
    color: #000;
    border: none;
    border-radius: 12px;
    padding: 18px;
    font-family: 'Bebas Neue', sans-serif;
    font-size: 1.3rem;
    letter-spacing: 2px;
    cursor: pointer;
    transition: all 0.2s;
    margin-top: 10px;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 10px;
    box-shadow: 0 8px 30px rgba(245,197,24,0.25);
  }

  .submit-btn:hover {
    transform: translateY(-2px);
    box-shadow: 0 12px 40px rgba(245,197,24,0.4);
  }

  .submit-btn:active { transform: scale(0.98); }

  .wa-icon { font-size: 1.3rem; }

  .form-note {
    text-align: center;
    font-size: 0.78rem;
    color: var(--muted);
    margin-top: 16px;
    line-height: 1.6;
  }

  /* STICKY CTA */
  .sticky-cta {
    position: fixed;
    bottom: 0; left: 0; right: 0;
    background: linear-gradient(135deg, var(--gold), #e6a800);
    color: #000;
    text-align: center;
    padding: 14px 20px;
    font-family: 'Bebas Neue', sans-serif;
    font-size: 1.1rem;
    letter-spacing: 2px;
    cursor: pointer;
    z-index: 100;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    box-shadow: 0 -4px 30px rgba(245,197,24,0.3);
    transition: all 0.2s;
  }

  .sticky-cta:hover { background: #FFD700; }

  /* FOOTER */
  footer {
    text-align: center;
    padding: 40px 20px 80px;
    color: var(--muted);
    font-size: 0.8rem;
    border-top: 1px solid rgba(255,255,255,0.05);
  }

  footer strong { color: var(--gold); }

  /* DIVIDER */
  .divider {
    height: 1px;
    background: linear-gradient(90deg, transparent, rgba(245,197,24,0.3), transparent);
    margin: 0 auto;
    max-width: 400px;
  }

  /* ANIMATIONS */
  @keyframes fadeUp {
    from { opacity: 0; transform: translateY(30px); }
    to { opacity: 1; transform: translateY(0); }
  }

  @keyframes bounce {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(8px); }
  }

  /* RESPONSIVE */
  @media (max-width: 600px) {
    .form-box { padding: 24px 18px; }
    .course-grid { grid-template-columns: 1fr; }
  }

  /* NO-SELECT HIGHLIGHT */
  .no-course-warning {
    color: #ff6b6b;
    font-size: 0.8rem;
    margin-top: 6px;
    display: none;
  }
</style>
</head>
