<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>G WORLD – Building Brands, Empowering Businesses</title>
<link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=DM+Sans:wght@300;400;500;600&family=DM+Serif+Display:ital@0;1&display=swap" rel="stylesheet">
<style>
:root {
  --gold: #F5C518;
  --gold-dim: rgba(245,197,24,0.15);
  --gold-glow: rgba(245,197,24,0.08);
  --dark: #080808;
  --dark2: #0e0e0e;
  --card: #111111;
  --card2: #161616;
  --border: rgba(255,255,255,0.07);
  --text: #f0ece4;
  --muted: #7a7060;
  --muted2: #aaa090;
}

*, *::before, *::after { margin:0; padding:0; box-sizing:border-box; }
html { scroll-behavior: smooth; }

body {
  background: var(--dark);
  color: var(--text);
  font-family: 'DM Sans', sans-serif;
  overflow-x: hidden;
}

/* ─── NAV ─── */
nav {
  position: fixed; top:0; left:0; right:0; z-index:200;
  display: flex; align-items: center; justify-content: space-between;
  padding: 18px 6%;
  background: rgba(8,8,8,0.85);
  backdrop-filter: blur(20px);
  border-bottom: 1px solid var(--border);
  transition: all 0.3s;
}

.nav-logo {
  font-family: 'Bebas Neue', sans-serif;
  font-size: 1.8rem;
  letter-spacing: 4px;
  color: var(--gold);
  text-decoration: none;
}

.nav-logo span { color: var(--text); }

.nav-links {
  display: flex; gap: 36px; list-style: none;
}

.nav-links a {
  color: var(--muted2);
  text-decoration: none;
  font-size: 0.82rem;
  letter-spacing: 1.5px;
  text-transform: uppercase;
  font-weight: 500;
  transition: color 0.2s;
}
.nav-links a:hover { color: var(--gold); }

.nav-cta {
  background: var(--gold);
  color: #000 !important;
  padding: 9px 22px;
  border-radius: 6px;
  font-weight: 600 !important;
}

.hamburger {
  display: none;
  flex-direction: column;
  gap: 5px;
  cursor: pointer;
  padding: 4px;
}
.hamburger span {
  width: 24px; height: 2px;
  background: var(--text);
  border-radius: 2px;
  transition: all 0.3s;
}

.mobile-menu {
  display: none;
  position: fixed;
  top: 65px; left:0; right:0;
  background: rgba(8,8,8,0.98);
  backdrop-filter: blur(20px);
  border-bottom: 1px solid var(--border);
  z-index: 199;
  padding: 20px 6% 30px;
  flex-direction: column;
  gap: 0;
}
.mobile-menu.open { display: flex; }
.mobile-menu a {
  color: var(--muted2);
  text-decoration: none;
  font-size: 1rem;
  letter-spacing: 1px;
  font-weight: 500;
  padding: 14px 0;
  border-bottom: 1px solid var(--border);
  transition: color 0.2s;
}
.mobile-menu a:hover { color: var(--gold); }

/* ─── HERO ─── */
.hero {
  min-height: 100vh;
  display: flex; flex-direction: column;
  align-items: center; justify-content: center;
  text-align: center;
  padding: 120px 6% 80px;
  position: relative;
  overflow: hidden;
}

.hero-bg {
  position: absolute; inset: 0;
  background:
    radial-gradient(ellipse 80% 60% at 50% 40%, rgba(245,197,24,0.07) 0%, transparent 70%),
    radial-gradient(circle at 20% 80%, rgba(245,197,24,0.04) 0%, transparent 40%);
}

.hero-grid {
  position: absolute; inset: 0;
  background-image:
    linear-gradient(rgba(255,255,255,0.02) 1px, transparent 1px),
    linear-gradient(90deg, rgba(255,255,255,0.02) 1px, transparent 1px);
  background-size: 60px 60px;
  mask-image: radial-gradient(ellipse 80% 80% at 50% 50%, black 30%, transparent 80%);
}

.hero-eyebrow {
  font-size: 0.7rem;
  letter-spacing: 4px;
  text-transform: uppercase;
  color: var(--gold);
  font-weight: 600;
  margin-bottom: 28px;
  position: relative;
  display: inline-flex; align-items: center; gap: 10px;
  animation: fadeUp 0.7s ease both;
}
.hero-eyebrow::before, .hero-eyebrow::after {
  content: ''; width: 30px; height: 1px; background: var(--gold); opacity: 0.5;
}

.hero h1 {
  font-family: 'Bebas Neue', sans-serif;
  font-size: clamp(5rem, 18vw, 13rem);
  line-height: 0.88;
  color: var(--gold);
  letter-spacing: 6px;
  position: relative;
  animation: fadeUp 0.7s ease 0.1s both;
  text-shadow: 0 0 120px rgba(245,197,24,0.2);
}

.hero-world {
  font-family: 'DM Serif Display', serif;
  font-style: italic;
  font-size: clamp(1.6rem, 4vw, 2.8rem);
  color: var(--text);
  letter-spacing: 2px;
  margin-top: 6px;
  animation: fadeUp 0.7s ease 0.18s both;
}

.hero-tagline {
  max-width: 560px;
  font-size: clamp(0.95rem, 2vw, 1.15rem);
  color: var(--muted2);
  line-height: 1.7;
  margin: 24px auto 0;
  font-weight: 300;
  animation: fadeUp 0.7s ease 0.26s both;
}

.hero-tagline strong { color: var(--text); font-weight: 500; }

.hero-btns {
  display: flex; gap: 14px; flex-wrap: wrap;
  justify-content: center;
  margin-top: 40px;
  animation: fadeUp 0.7s ease 0.34s both;
}

.btn-primary {
  background: var(--gold);
  color: #000;
  padding: 14px 32px;
  border-radius: 8px;
  font-weight: 700;
  font-size: 0.9rem;
  letter-spacing: 1px;
  text-decoration: none;
  text-transform: uppercase;
  transition: all 0.2s;
  box-shadow: 0 6px 30px rgba(245,197,24,0.25);
}
.btn-primary:hover { transform: translateY(-2px); box-shadow: 0 10px 40px rgba(245,197,24,0.4); }

.btn-ghost {
  background: transparent;
  color: var(--text);
  padding: 13px 32px;
  border-radius: 8px;
  font-weight: 500;
  font-size: 0.9rem;
  letter-spacing: 1px;
  text-decoration: none;
  text-transform: uppercase;
  border: 1px solid var(--border);
  transition: all 0.2s;
}
.btn-ghost:hover { border-color: var(--gold); color: var(--gold); }

.hero-stats {
  display: flex; gap: 48px; flex-wrap: wrap; justify-content: center;
  margin-top: 70px;
  padding-top: 40px;
  border-top: 1px solid var(--border);
  animation: fadeUp 0.7s ease 0.42s both;
}

.stat-item { text-align: center; }
.stat-num {
  font-family: 'Bebas Neue', sans-serif;
  font-size: 2.8rem;
  color: var(--gold);
  letter-spacing: 2px;
  line-height: 1;
}
.stat-label {
  font-size: 0.72rem;
  letter-spacing: 2px;
  text-transform: uppercase;
  color: var(--muted);
  margin-top: 4px;
}

/* ─── SECTION SHARED ─── */
.section-wrap {
  max-width: 1200px;
  margin: 0 auto;
  padding: 100px 6%;
}

.section-header {
  margin-bottom: 60px;
}

.s-label {
  font-size: 0.68rem;
  letter-spacing: 4px;
  text-transform: uppercase;
  color: var(--gold);
  font-weight: 600;
  margin-bottom: 12px;
  display: flex; align-items: center; gap: 10px;
}
.s-label::after { content:''; flex:1; height:1px; background: var(--gold); opacity:0.2; max-width:80px; }

.s-title {
  font-family: 'Bebas Neue', sans-serif;
  font-size: clamp(2.4rem, 5vw, 4rem);
  line-height: 1;
  letter-spacing: 2px;
}

.s-sub {
  color: var(--muted2);
  font-size: 1rem;
  line-height: 1.7;
  max-width: 580px;
  margin-top: 14px;
  font-weight: 300;
}

/* ─── ABOUT ─── */
#about { background: var(--dark2); border-top: 1px solid var(--border); border-bottom: 1px solid var(--border); }

.about-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 80px;
  align-items: center;
}

.about-left .big-letter {
  font-family: 'Bebas Neue', sans-serif;
  font-size: 18rem;
  color: rgba(245,197,24,0.04);
  line-height: 0.8;
  position: absolute;
  left: -20px; top: -40px;
  pointer-events: none;
  user-select: none;
}

.about-left { position: relative; }

.about-badge {
  display: inline-flex; align-items: center; gap: 8px;
  background: var(--gold-dim);
  border: 1px solid rgba(245,197,24,0.2);
  color: var(--gold);
  padding: 6px 16px;
  border-radius: 50px;
  font-size: 0.72rem;
  letter-spacing: 2px;
  text-transform: uppercase;
  font-weight: 600;
  margin-bottom: 24px;
}

.about-left h2 {
  font-family: 'DM Serif Display', serif;
  font-size: clamp(2rem, 3.5vw, 2.8rem);
  line-height: 1.25;
  margin-bottom: 20px;
}

.about-left h2 em { font-style: italic; color: var(--gold); }

.about-left p {
  color: var(--muted2);
  line-height: 1.8;
  font-size: 0.95rem;
  margin-bottom: 16px;
  font-weight: 300;
}

.about-right {
  display: flex; flex-direction: column; gap: 20px;
}

.about-pillar {
  background: var(--card);
  border: 1px solid var(--border);
  border-radius: 14px;
  padding: 24px 26px;
  display: flex; gap: 18px; align-items: flex-start;
  transition: all 0.25s;
}
.about-pillar:hover {
  border-color: rgba(245,197,24,0.25);
  background: var(--card2);
  transform: translateX(4px);
}

.pillar-icon {
  font-size: 1.5rem;
  width: 46px; height: 46px;
  background: var(--gold-dim);
  border-radius: 10px;
  display: flex; align-items: center; justify-content: center;
  flex-shrink: 0;
}

.pillar-title {
  font-weight: 600;
  font-size: 0.92rem;
  margin-bottom: 5px;
  color: var(--text);
}
.pillar-text {
  font-size: 0.82rem;
  color: var(--muted);
  line-height: 1.6;
  font-weight: 300;
}

/* ─── BUSINESS ─── */
#business { background: var(--dark); }

.services-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 16px;
}

.service-card {
  background: var(--card);
  border: 1px solid var(--border);
  border-radius: 16px;
  padding: 32px 28px;
  transition: all 0.3s;
  position: relative;
  overflow: hidden;
}

.service-card::before {
  content: '';
  position: absolute; bottom: 0; left: 0; right: 0; height: 3px;
  background: linear-gradient(90deg, var(--gold), transparent);
  opacity: 0;
  transition: opacity 0.3s;
}
.service-card:hover { border-color: rgba(245,197,24,0.2); transform: translateY(-4px); box-shadow: 0 20px 60px rgba(0,0,0,0.4); }
.service-card:hover::before { opacity: 1; }

.service-icon {
  font-size: 2rem;
  margin-bottom: 18px;
  display: block;
}
.service-title {
  font-family: 'Bebas Neue', sans-serif;
  font-size: 1.4rem;
  letter-spacing: 1.5px;
  color: var(--text);
  margin-bottom: 10px;
}
.service-desc {
  font-size: 0.85rem;
  color: var(--muted);
  line-height: 1.7;
  font-weight: 300;
}

/* ─── WHY US ─── */
#why { background: var(--dark2); border-top: 1px solid var(--border); border-bottom: 1px solid var(--border); }

.why-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 2px;
  border: 1px solid var(--border);
  border-radius: 20px;
  overflow: hidden;
}

.why-item {
  padding: 36px 28px;
  background: var(--card);
  border-right: 1px solid var(--border);
  border-bottom: 1px solid var(--border);
  transition: background 0.2s;
}
.why-item:hover { background: var(--card2); }
.why-item:nth-child(4n) { border-right: none; }
.why-item:nth-last-child(-n+4) { border-bottom: none; }

.why-num {
  font-family: 'Bebas Neue', sans-serif;
  font-size: 3rem;
  color: rgba(245,197,24,0.15);
  line-height: 1;
  margin-bottom: 10px;
}
.why-title {
  font-size: 0.88rem;
  font-weight: 600;
  color: var(--text);
  margin-bottom: 8px;
}
.why-text {
  font-size: 0.78rem;
  color: var(--muted);
  line-height: 1.6;
  font-weight: 300;
}

/* ─── EDUCATION / COURSES ─── */
#education { background: var(--dark); }

.edu-top {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 60px;
  align-items: center;
  margin-bottom: 60px;
}

.edu-right {
  background: var(--card);
  border: 1px solid rgba(245,197,24,0.15);
  border-radius: 20px;
  padding: 32px;
  position: relative;
  overflow: hidden;
}
.edu-right::before {
  content: '';
  position: absolute; top:-60px; right:-60px;
  width:200px; height:200px;
  border-radius: 50%;
  background: radial-gradient(circle, rgba(245,197,24,0.08), transparent 70%);
}

.price-big {
  font-family: 'Bebas Neue', sans-serif;
  font-size: 5rem;
  color: var(--gold);
  line-height: 1;
  letter-spacing: 2px;
}
.price-big span { font-size: 2rem; vertical-align: top; margin-top: 16px; display: inline-block; }
.price-desc {
  color: var(--muted2);
  font-size: 0.88rem;
  margin-top: 6px;
  margin-bottom: 24px;
  font-weight: 300;
}

.course-count-badge {
  display: inline-flex; align-items: center; gap: 8px;
  background: var(--gold-dim);
  border: 1px solid rgba(245,197,24,0.2);
  color: var(--gold);
  padding: 8px 18px;
  border-radius: 50px;
  font-size: 0.78rem;
  font-weight: 600;
  letter-spacing: 1px;
  margin-bottom: 20px;
}

.course-topics {
  display: flex; flex-direction: column; gap: 8px;
  margin-bottom: 28px;
}
.course-topic {
  display: flex; align-items: center; gap: 10px;
  font-size: 0.85rem;
  color: var(--muted2);
}
.course-topic::before {
  content: '→';
  color: var(--gold);
  font-size: 0.75rem;
  flex-shrink: 0;
}

.enroll-btn {
  display: flex; align-items: center; justify-content: center; gap: 10px;
  width: 100%;
  background: linear-gradient(135deg, var(--gold), #e0a800);
  color: #000;
  text-decoration: none;
  padding: 16px;
  border-radius: 10px;
  font-family: 'Bebas Neue', sans-serif;
  font-size: 1.3rem;
  letter-spacing: 2px;
  transition: all 0.2s;
  box-shadow: 0 8px 30px rgba(245,197,24,0.25);
}
.enroll-btn:hover { transform: translateY(-2px); box-shadow: 0 12px 40px rgba(245,197,24,0.4); }

/* ─── VISION / MISSION STRIP ─── */
.vm-strip {
  background: var(--card2);
  border-top: 1px solid var(--border);
  border-bottom: 1px solid var(--border);
  padding: 0;
}

.vm-inner {
  max-width: 1200px;
  margin: 0 auto;
  display: grid;
  grid-template-columns: 1fr 1fr;
}

.vm-block {
  padding: 60px 6%;
}
.vm-block:first-child {
  border-right: 1px solid var(--border);
}

.vm-label {
  font-size: 0.68rem;
  letter-spacing: 4px;
  text-transform: uppercase;
  color: var(--gold);
  font-weight: 600;
  margin-bottom: 16px;
}

.vm-title {
  font-family: 'Bebas Neue', sans-serif;
  font-size: 2.2rem;
  letter-spacing: 2px;
  margin-bottom: 14px;
}

.vm-text {
  color: var(--muted2);
  font-size: 0.9rem;
  line-height: 1.8;
  font-weight: 300;
}

/* ─── CONTACT ─── */
#contact {
  background: var(--dark);
  padding-bottom: 0;
}

.contact-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 60px;
  align-items: start;
}

.contact-info { display: flex; flex-direction: column; gap: 20px; }

.contact-item {
  display: flex; gap: 16px; align-items: flex-start;
  background: var(--card);
  border: 1px solid var(--border);
  border-radius: 12px;
  padding: 20px 22px;
  transition: border-color 0.2s;
}
.contact-item:hover { border-color: rgba(245,197,24,0.3); }

.contact-icon {
  font-size: 1.3rem;
  width: 42px; height: 42px;
  background: var(--gold-dim);
  border-radius: 10px;
  display: flex; align-items: center; justify-content: center;
  flex-shrink: 0;
}

.contact-label {
  font-size: 0.7rem;
  letter-spacing: 2px;
  text-transform: uppercase;
  color: var(--muted);
  margin-bottom: 4px;
  font-weight: 600;
}

.contact-value {
  font-size: 0.95rem;
  font-weight: 500;
  color: var(--text);
}

.wa-big-btn {
  display: flex; align-items: center; justify-content: center; gap: 12px;
  background: #25D366;
  color: #fff;
  text-decoration: none;
  padding: 18px 30px;
  border-radius: 12px;
  font-family: 'Bebas Neue', sans-serif;
  font-size: 1.3rem;
  letter-spacing: 2px;
  transition: all 0.2s;
  box-shadow: 0 8px 30px rgba(37,211,102,0.2);
  margin-top: 10px;
}
.wa-big-btn:hover { transform: translateY(-2px); box-shadow: 0 12px 40px rgba(37,211,102,0.35); }

.contact-form-box {
  background: var(--card);
  border: 1px solid var(--border);
  border-radius: 20px;
  padding: 36px;
}

.cf-title {
  font-family: 'Bebas Neue', sans-serif;
  font-size: 1.8rem;
  letter-spacing: 2px;
  margin-bottom: 24px;
  color: var(--text);
}

.cf-group { margin-bottom: 16px; }
.cf-group label {
  display: block;
  font-size: 0.7rem;
  letter-spacing: 2px;
  text-transform: uppercase;
  color: var(--muted);
  font-weight: 600;
  margin-bottom: 7px;
}
.cf-group input,
.cf-group textarea {
  width: 100%;
  background: var(--dark2);
  border: 1px solid rgba(255,255,255,0.07);
  border-radius: 9px;
  padding: 13px 15px;
  color: var(--text);
  font-family: 'DM Sans', sans-serif;
  font-size: 0.9rem;
  outline: none;
  transition: border 0.2s;
}
.cf-group input:focus,
.cf-group textarea:focus { border-color: var(--gold); box-shadow: 0 0 0 3px rgba(245,197,24,0.08); }
.cf-group textarea { resize: vertical; min-height: 110px; }

.cf-submit {
  width: 100%;
  background: var(--gold);
  color: #000;
  border: none;
  border-radius: 9px;
  padding: 15px;
  font-family: 'Bebas Neue', sans-serif;
  font-size: 1.2rem;
  letter-spacing: 2px;
  cursor: pointer;
  transition: all 0.2s;
  margin-top: 6px;
}
.cf-submit:hover { background: #FFD700; transform: translateY(-1px); }

/* ─── FOOTER ─── */
footer {
  background: var(--dark2);
  border-top: 1px solid var(--border);
  padding: 50px 6% 30px;
  margin-top: 100px;
}

.footer-inner {
  max-width: 1200px;
  margin: 0 auto;
}

.footer-top {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  margin-bottom: 40px;
  flex-wrap: wrap;
  gap: 30px;
}

.footer-logo {
  font-family: 'Bebas Neue', sans-serif;
  font-size: 2.5rem;
  letter-spacing: 4px;
  color: var(--gold);
}
.footer-logo span { color: var(--text); }

.footer-tagline {
  font-size: 0.82rem;
  color: var(--muted);
  margin-top: 4px;
  font-style: italic;
}

.footer-links {
  display: flex; gap: 30px; flex-wrap: wrap;
}
.footer-links a {
  color: var(--muted);
  text-decoration: none;
  font-size: 0.82rem;
  letter-spacing: 1px;
  transition: color 0.2s;
}
.footer-links a:hover { color: var(--gold); }

.footer-bottom {
  border-top: 1px solid var(--border);
  padding-top: 20px;
  display: flex;
  justify-content: space-between;
  align-items: center;
  flex-wrap: wrap;
  gap: 10px;
}

.footer-copy {
  font-size: 0.75rem;
  color: var(--muted);
}

.footer-country {
  font-size: 0.75rem;
  color: var(--muted);
  display: flex; align-items: center; gap: 6px;
}

/* ─── ANIMATIONS ─── */
@keyframes fadeUp {
  from { opacity:0; transform:translateY(28px); }
  to   { opacity:1; transform:translateY(0); }
}

.reveal {
  opacity: 0;
  transform: translateY(30px);
  transition: opacity 0.7s ease, transform 0.7s ease;
}
.reveal.visible {
  opacity: 1;
  transform: translateY(0);
}

/* ─── RESPONSIVE ─── */
@media (max-width: 900px) {
  .nav-links { display: none; }
  .hamburger { display: flex; }
  .about-grid,
  .contact-grid,
  .edu-top { grid-template-columns: 1fr; gap: 40px; }
  .services-grid { grid-template-columns: 1fr 1fr; }
  .why-grid { grid-template-columns: 1fr 1fr; }
  .why-item:nth-child(2n) { border-right: none; }
  .why-item:nth-child(4n) { border-right: 1px solid var(--border); }
  .vm-inner { grid-template-columns: 1fr; }
  .vm-block:first-child { border-right: none; border-bottom: 1px solid var(--border); }
  .footer-top { flex-direction: column; }
  .about-left .big-letter { display: none; }
}

